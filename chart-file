    {
        return $this->hasOne(TestSample::class, 'lab_test_id', 'id');
    }

    public function receipt(): HasOne
    {
        return $this->hasOne(LabReceipt::class, 'id', 'lab_id');
    }

    public function test(): BelongsTo
    {
        return $this->belongsTo(Test::class, 'test_id', 'id');
    }

