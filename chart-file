    {
        return $this->hasOne(User::class, 'id', 'collected_by')
            ->withoutGlobalScope(SelfTenantScope::class);
    }

    public function prepared(): HasOne
    {
        return $this->hasOne(User::class, 'id', 'prepared_by')
            ->withoutGlobalScope(SelfTenantScope::class);
    }

    public function reviewed(): HasOne
    {
        return $this->hasOne(User::class, 'id', 'reviewed_by')
            ->withoutGlobalScope(SelfTenantScope::class);
    }

    public function authorized(): HasOne
    {
        return $this->hasOne(User::class, 'id', 'authorized_by')
            ->withoutGlobalScope(SelfTenantScope::class);
    }

    public function genSl($test_id): string
    {
        $prefix = Carbon::now()->format('ymd');
        $latestBarcode = LabTest::withTrashed()->where('sl_no', 'like', $prefix.'%')
            ->where('test_id', $test_id)
            ->max('sl_no');

