    protected function baseUnit(): Attribute
    {
        return Attribute::make(
            get: fn ($value) => $this->unit ?? ''
        );
    }

    protected function unit(): Attribute
    {
        return Attribute::make(
            get: fn ($value) => $this->getOverrideCached('unit') ?? $value
        );
    }

    protected function convertUnit(): Attribute
    {
        return Attribute::make(
            get: fn ($value) => $this->getOverrideCached('convert_unit') ?? $value
        );
    }

    protected function factor(): Attribute
    {
        return Attribute::make(
            get: fn ($value) => $this->getOverrideCached('factor') ?? $value
        );
    }

    protected function status(): Attribute
    {
        return Attribute::make(
            get: fn ($value) => $this->getOverrideCached('status') ?? $value
        );
    }

    protected function getOverrideCached($attribute = null)
    {

        $tenantId = auth()->user()->tenant_id ?? webTenant();

        $Override = Cache::remember("test_component_{$this->id}_tenant_".$tenantId, 3600, function () {
            return $this->Override()->first();
        });

        return $attribute ? ($Override?->$attribute ?? null) : $Override;
    }

    public function references()
    {
        return $this->hasMany(TestComponentReference::class, 'test_component_id', 'id')->withTrashed();
    }
